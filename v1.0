<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pannonische Kulturroute</title>
    
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=MedievalSharp&display=swap');
        .font-serif { font-family: 'Inter', serif; }
        .font-display { font-family: 'MedievalSharp', cursive; }
        #map { height: 100vh; width: 100vw; position: absolute; top: 0; left: 0; z-index: 0; }
        .medieval-shadow { shadow-[0_0_30px_rgba(0,0,0,0.7)]; }
        .line-clamp-4 { display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        const locations = [
            {
                name: 'Willkommen zur Kulturroute',
                name_hu: 'Üdvözöljük a Kulturúton',
                coords: [47.22, 16.35],
                text: 'Entdecken Sie den Alltag im Mittelalter im Südburgenland und Komitat Vas. Diese Route verbindet historische Orte zu einem authentischen Erlebnis[cite: 49, 50].',
                text_hu: 'Fedezze fel a középkori mindennapokat Dél-Burgenlandban és Vas vármegyében. Ez az útvonal történelmi helyszíneket köt össze egy hiteles élmény érdekében[cite: 49, 50].',
                image: 'https://images.unsplash.com/photo-1599412227383-b7d4751c8765?q=80&w=800'
            },
            // Hier folgen deine 15+ Stationen (Litzelsdorf, Kemeten, Wolfau, Szombathely, Kőszeg, Vasvár)...
            {
                name: 'Litzelsdorf: Ringwallanlage',
                name_hu: 'Litzelsdorf: Sáncrendszer',
                coords: [47.2033, 16.1325],
                text: 'Rekonstruierte mittelalterliche Ringwallanlage als multifunktionale Bühne. Macht die historische Verteidigungsarchitektur erlebbar[cite: 276].',
                text_hu: 'Rekonstruált középkori sáncrendszer, amely színpadként szolgál[cite: 276].',
                image: 'https://images.unsplash.com/photo-1599412227383-b7d4751c8765?q=80&w=800'
            },
            // ... (weitere Orte wie im vorherigen Chat besprochen einfügen)
        ];

        function App() {
            const [currentIndex, setCurrentIndex] = useState(0);
            const [lang, setLang] = useState('de');
            const [isExpanded, setIsExpanded] = useState(false);
            const mapRef = useRef(null);
            const polylineRef = useRef(null);

            useEffect(() => {
                const map = L.map('map', { zoomControl: false }).setView(locations[0].coords, 9);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
                L.control.zoom({ position: 'topright' }).addTo(map);

                const coords = locations.map(l => l.coords);
                const poly = L.polyline(coords, { 
                    color: '#8b5a2b', 
                    dashArray: '10, 10', 
                    smoothFactor: 2.0,
                    opacity: 0.8 
                }).addTo(map);
                
                polylineRef.current = poly;
                mapRef.current = map;

                // Zoom-Logik für Polyline
                map.on('zoomend', () => {
                    const zoom = map.getZoom();
                    poly.setStyle({ opacity: zoom < 13 ? 0.8 : 0 });
                });

                return () => map.remove();
            }, []);

            useEffect(() => {
                if (mapRef.current) {
                    const loc = locations[currentIndex];
                    if (currentIndex === 0) {
                        mapRef.current.fitBounds(polylineRef.current.getBounds(), { padding: [50, 50] });
                    } else {
                        mapRef.current.flyTo(loc.coords, 15);
                    }
                }
            }, [currentIndex]);

            // Dots-Logik (Sliding Window von 6 Dots)
            const getVisibleDots = () => {
                let start = Math.max(0, currentIndex - 2);
                let end = Math.min(locations.length, start + 6);
                if (end === locations.length) start = Math.max(0, end - 6);
                return Array.from({length: end - start}, (_, i) => start + i);
            };

            const loc = locations[currentIndex];

            return (
                <div className="relative w-full h-screen overflow-hidden bg-[#2c1e16]">
                    <div id="map"></div>

                    {/* Language Switch */}
                    <div className="absolute top-4 left-4 z-[1000] flex bg-[#fdf6e3] border-2 border-[#8b5a2b] rounded-sm shadow-lg overflow-hidden">
                        <button onClick={() => setLang('de')} className={`px-4 py-2 font-bold ${lang === 'de' ? 'bg-[#8b5a2b] text-white' : 'text-[#8b5a2b]'}`}>DE</button>
                        <button onClick={() => setLang('hu')} className={`px-4 py-2 font-bold ${lang === 'hu' ? 'bg-[#8b5a2b] text-white' : 'text-[#8b5a2b]'}`}>HU</button>
                    </div>

                    {/* Info Card */}
                    <div className="absolute bottom-0 left-0 right-0 md:top-0 md:left-4 md:w-96 z-[1000] p-4 pointer-events-none md:h-full">
                        <div className="bg-[#fdf6e3] border-4 border-double border-[#8b5a2b] rounded-sm overflow-hidden flex flex-col pointer-events-auto shadow-2xl h-fit max-h-[80vh] md:max-h-[90vh]">
                            <img src={loc.image} className="h-40 md:h-56 object-cover sepia-[.3]" />
                            <div className="p-6 overflow-y-auto">
                                <h2 className="text-2xl font-display text-[#8b5a2b] mb-4">{lang === 'de' ? loc.name : loc.name_hu}</h2>
                                <p className={`text-[#3e2723] leading-relaxed ${!isExpanded ? 'line-clamp-4' : ''}`}>
                                    {lang === 'de' ? loc.text : loc.text_hu}
                                </p>
                                {loc.text.length > 150 && (
                                    <button onClick={() => setIsExpanded(!isExpanded)} className="text-[#8b5a2b] font-bold mt-2 underline">
                                        {isExpanded ? (lang === 'de' ? 'Weniger' : 'Kevesebb') : (lang === 'de' ? 'Mehr lesen...' : 'Bővebben...')}
                                    </button>
                                )}
                            </div>

                            {/* Footer Navigation */}
                            <div className="p-4 bg-[#f4ebd0] border-t-2 border-[#8b5a2b] flex items-center justify-between">
                                <button onClick={() => setCurrentIndex(prev => (prev - 1 + locations.length) % locations.length)} className="p-2 border-2 border-[#8b5a2b] text-[#8b5a2b]">◀</button>
                                <div className="flex gap-2">
                                    {getVisibleDots().map(idx => (
                                        <div key={idx} onClick={() => setCurrentIndex(idx)} className={`w-3 h-3 rotate-45 border border-[#8b5a2b] cursor-pointer ${idx === currentIndex ? 'bg-[#8b5a2b]' : 'bg-white opacity-40'}`}></div>
                                    ))}
                                </div>
                                <button onClick={() => setCurrentIndex(prev => (prev + 1) % locations.length)} className="p-2 border-2 border-[#8b5a2b] text-[#8b5a2b]">▶</button>
                            </div>
                        </div>
                    </div>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
